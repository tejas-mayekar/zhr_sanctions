<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
>
    <Dialog
        id="AddQuestionsDialog"
        title="Add Questions"
        icon="sap-icon://add-activity"
        contentWidth="30rem"
        resizable="true"
        draggable="true"
    >
        <content>
            <VBox
                id="_IDGenQuestionsWrapper"
                class="sapUiSmallMargin"
            >
                <VBox
                    id="questionsListBox"
                    items="{questions>/questions}"
                >
                    <VBox id="_IDGenVBox20" class="sapUiTinyMarginBottom">
                        <Label id="_IDGenLabel140" text="Question" design="Bold"/>
                        <Input
                            id="_IDGenQuestionInput"
                            value="{questions>question}"
                            placeholder="Enter question"
                            width="100%"
                            class="sapUiTinyMarginBottom"
                        />
                        <Label id="_IDGenLabel141" text="Answer" design="Bold"/>
                        <TextArea
                        rows="4"
                            id="_IDGenAnswerInput"
                            value="{questions>answer}"
                            placeholder="Enter answer"
                            width="100%"
                            class="sapUiSmallMarginBottom"
                        />
                    </VBox>
                </VBox>
                <Button
                    id="btnAddQuestionRow"
                    text="Add"
                    icon="sap-icon://add"
                    type="Transparent"
                    press=".onAddQuestionPress"
                    class="sapUiTinyMarginTop"
                />
            </VBox>
        </content>

        <beginButton>
            <Button
                id="btnSaveQuestions"
                text="Save"
                type="Emphasized"
                press=".onSaveQuestionsPress"
            />
        </beginButton>
        <endButton>
            <Button
                id="btnCancelQuestions"
                text="Cancel"
                press=".onCancelQuestionsPress"
            />
        </endButton>
    </Dialog>
</core:FragmentDefinition>