<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:form="sap.ui.layout.form"
>
    <Dialog
        id="AddRemarkDialog"
        title="Remarks"
        icon="sap-icon://comment"
        contentWidth="56rem"
        resizable="true"
        draggable="true"
    >
        <content>
            <List
                id="remarksList"
                items="{remarks>/results}"
                noDataText="No remarks found"
                showSeparators="Inner"
            >
                <CustomListItem id="_IDGenCustomListItem">
    <FormattedText id="_IDGenFormattedText"
        htmlText="{
            path: 'remarks>Tdline',
            formatter: '.formatRemarkColor'
        }"
        class="sapUiSmallMargin"
    />
</CustomListItem>
            </List>
        </content>

        <endButton>
            <Button
                id="_IDGenButton20"
                text="Cancel"
                press=".onViewRemarkCancel"
            />
        </endButton>
    </Dialog>
</core:FragmentDefinition>
