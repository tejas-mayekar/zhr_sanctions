<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:form="sap.ui.layout.form"
>
    <Dialog
        id="regularizeDialog"
        title="{regularize>/dialogTitle}"
        icon="sap-icon://edit"
        contentWidth="70rem"
        resizable="true"
        draggable="true"
    >
        <content>
            <VBox
                id="_IDGenVBox9"
                class="sapUiSmallMargin"
            >
                <!-- ── Info Strip ── -->
                <MessageStrip
                    id="regularizeInfoStrip"
                    text="Regularizing record {detailData>/record/ZACTION_REF_NO} for {detailData>/record/ZempName} on {detailData>/record/ZincDate}"
                    type="Information"
                    showIcon="true"
                    showCloseButton="false"
                    class="sapUiSmallMarginBottom"
                />

                <!-- ── Context Summary ── -->
                <Panel
                    id="regularizeSummaryPanel"
                    headerText="Attendance Summary"
                    expandable="false"
                    class="sapUiSmallMarginBottom"
                >
                    <form:SimpleForm
                        id="regularizeSummaryForm"
                        editable="false"
                        layout="ResponsiveGridLayout"
                        labelSpanL="6"
                        labelSpanM="6"
                        labelSpanS="12"
                        columnsL="2"
                        columnsM="2"
                    >
                        <form:content>
                            <Label
                                id="lblPlannedIn"
                                text="Planned Clock-In"
                            />
                            <Text
                                id="txtPlannedIn"
                                text="{regularize>/scheduledIn}"
                            />

                            <Label
                                id="lblPlannedOut"
                                text="Planned Clock-Out"
                            />
                            <Text
                                id="txtPlannedOut"
                                text="{regularize>/scheduledOut}"
                            />

                            <Label
                                id="lblActualIn"
                                text="Actual Clock-In"
                            />
                            <Text
                                id="txtActualIn"
                                text="{regularize>/punchIn}"
                            />

                            <Label
                                id="lblActualOut"
                                text="Actual Clock-Out"
                            />
                            <Text
                                id="txtActualOut"
                                text="{regularize>/punchOut}"
                            />

                            <Label
                                id="lblDelayHrs"
                                text="Delay Hours"
                                visible="{regularize>/hasDelay}"
                            />
                            <Text
                                id="txtDelayHrs"
                                text="{regularize>/delayHrs}"
                                visible="{regularize>/hasDelay}"
                            />

                            <Label
                                id="lblShortHrs"
                                text="Short Hours"
                                visible="{regularize>/hasShort}"
                            />
                            <Text
                                id="txtShortHrs"
                                text="{regularize>/shortHrs}"
                                visible="{regularize>/hasShort}"
                            />
                        </form:content>
                    </form:SimpleForm>
                </Panel>

                <!-- ── Mode Selector: RadioButtonGroup — only when BOTH apply ── -->
                <VBox
                    id="regularizeModeBox"
                    visible="{regularize>/showModeSelector}"
                    class="sapUiSmallMarginBottom"
                >
                    <Label
                        id="lblRegMode"
                        text="Regularization Type"
                        required="true"
                        class="sapUiSmallMarginBottom"
                    />
                    <RadioButtonGroup
                        id="regularizeModeRadio"
                        columns="3"
                        select=".onRegularizeModeChange"
                    >
                        <buttons>
                            <RadioButton
                                id="modeDelay"
                                text="Delay Only"
                                groupName="regMode"
                            />
                            <RadioButton
                                id="modeShort"
                                text="Short Only"
                                groupName="regMode"
                            />
                            <RadioButton
                                id="modeBoth"
                                text="Both"
                                groupName="regMode"
                                selected="true"
                            />
                        </buttons>
                    </RadioButtonGroup>
                </VBox>

                <!-- ── Delay Section ── -->
                <VBox
                    id="regularizeDelayBox"
                    visible="{regularize>/showDelay}"
                    class="sapUiSmallMarginBottom"
                >
                    <Title
                        id="titleDelaySection"
                        text="Regularize Delay Hours"
                        level="H5"
                        class="sapUiSmallMarginBottom"
                    />
                    <form:SimpleForm
                        id="formDelaySection"
                        editable="true"
                        layout="ResponsiveGridLayout"
                        labelSpanL="4"
                        labelSpanM="4"
                        labelSpanS="12"
                        columnsL="2"
                        columnsM="2"
                    >
                        <form:content>
                            <Label
                                id="lblDelayFrom"
                                text="From Time"
                                required="true"
                            />
                            <TimePicker
                                id="regularizeDelayFrom"
                                value="{regularize>/delayFrom}"
                                valueFormat="HH:mm:ss"
                                displayFormat="hh:mm:ss a"
                                placeholder="HH:MM:SS"
                                width="100%"
                            />
                            <Label
                                id="lblDelayTo"
                                text="To Time"
                                required="true"
                            />
                            <TimePicker
                                id="regularizeDelayTo"
                                value="{regularize>/delayTo}"
                                valueFormat="HH:mm:ss"
                                displayFormat="hh:mm:ss a"
                                placeholder="HH:MM:SS"
                                width="100%"
                            />
                        </form:content>
                    </form:SimpleForm>
                </VBox>

                <!-- ── Short Section ── -->
                <VBox
                    id="regularizeShortBox"
                    visible="{regularize>/showShort}"
                    class="sapUiSmallMarginBottom"
                >
                    <Title
                        id="titleShortSection"
                        text="Regularize Short Hours"
                        level="H5"
                        class="sapUiSmallMarginBottom"
                    />
                    <form:SimpleForm
                        id="formShortSection"
                        editable="true"
                        layout="ResponsiveGridLayout"
                        labelSpanL="4"
                        labelSpanM="4"
                        labelSpanS="12"
                        columnsL="2"
                        columnsM="2"
                    >
                        <form:content>
                            <Label
                                id="lblShortFrom"
                                text="From Time"
                                required="true"
                            />
                            <TimePicker
                                id="regularizeShortFrom"
                                value="{regularize>/shortFrom}"
                                valueFormat="HH:mm:ss"
                                displayFormat="hh:mm:ss a"
                                placeholder="HH:MM:SS"
                                width="100%"
                            />
                            <Label
                                id="lblShortTo"
                                text="To Time"
                                required="true"
                            />
                            <TimePicker
                                id="regularizeShortTo"
                                value="{regularize>/shortTo}"
                                valueFormat="HH:mm:ss"
                                displayFormat="hh:mm:ss a"
                                placeholder="HH:MM:SS"
                                width="100%"
                            />
                        </form:content>
                    </form:SimpleForm>
                </VBox>
                <!-- ── Unauth Section ── -->
                <VBox
                    id="regularizeUnauthBox"
                    visible="{regularize>/showUnauth}"
                    class="sapUiSmallMarginBottom"
                >
                    <Title
                        id="titleUnauthSection"
                        text="Regularize Unauthorized Absence"
                        level="H5"
                        class="sapUiSmallMarginBottom"
                    />
                    <form:SimpleForm
                        id="formUnauthSection"
                        editable="true"
                        layout="ResponsiveGridLayout"
                        labelSpanL="4"
                        labelSpanM="4"
                        labelSpanS="12"
                        columnsL="2"
                        columnsM="2"
                    >
                        <form:content>
                            <Label
                                id="lblUnauthIn"
                                text="Punch In Time"
                                required="true"
                            />
                            <TimePicker
                                id="regularizeUnauthPunchIn"
                                value="{regularize>/unauthPunchIn}"
                                valueFormat="HH:mm:ss"
                                displayFormat="hh:mm:ss a"
                                placeholder="HH:MM:SS"
                                width="100%"
                            />
                            <Label
                                id="lblUnauthOut"
                                text="Punch Out Time"
                                required="true"
                            />
                            <TimePicker
                                id="regularizeUnauthPunchOut"
                                value="{regularize>/unauthPunchOut}"
                                valueFormat="HH:mm:ss"
                                displayFormat="hh:mm:ss a"
                                placeholder="HH:MM:SS"
                                width="100%"
                            />
                        </form:content>
                    </form:SimpleForm>
                </VBox>
                <!-- ── Reason ── -->
                <Label
                    id="_IDGenLabel66"
                    text="Reason / Remarks"
                    required="true"
                    class="sapUiSmallMarginTop"
                />
                <TextArea
                    id="regularizeReason"
                    value="{regularize>/reason}"
                    rows="3"
                    maxLength="255"
                    growing="false"
                    width="100%"
                    placeholder="Enter reason for regularization..."
                />
            </VBox>
        </content>

        <beginButton>
            <Button
                id="btnRegularizeSubmit"
                text="Submit"
                type="Emphasized"
                press=".onRegularizeSubmit"
            />
        </beginButton>
        <endButton>
            <Button
                id="btnRegularizeCancel"
                text="Cancel"
                press=".onRegularizeCancel"
            />
        </endButton>
    </Dialog>
</core:FragmentDefinition>
