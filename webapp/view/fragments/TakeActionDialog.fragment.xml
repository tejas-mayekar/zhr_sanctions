<core:FragmentDefinition
    xmlns:core="sap.ui.core"
    xmlns:f="sap.f"
    xmlns="sap.m"
>
    <Dialog
        id="TakeActionDialog"
        title="Take Action"
        type="Standard"
        class="sapUiResponsiveMargin"
        contentWidth="600px"
    >
        <content>
            <VBox
                id="_IDGenVBox12"
                class="sapUiMediumMargin"
            >
                <Label
                    id="_IDGenLabel83"
                    text="Violation Category"
                    required="true"
                />
                <InputListItem
                    id="_IDGenInputListItem"
                    label="Enter Violation Category"
                >
                    <Select id="violation_type">
                        <core:Item
                            id="_IDGenItem"
                            key="A"
                            text="A - Violations related to working hours"
                        />
                        <core:Item
                            id="_IDGenItem2"
                            key="B"
                            text="B - Violations related to work organization"
                        />
                        <core:Item
                            id="_IDGenItem3"
                            key="C"
                            text="C - Violations related to employee conduct "
                        />
                    </Select>
                </InputListItem>
                <Label
                    id="_IDGenLabel84"
                    text="Incident Type"
                    required="true"
                    class="sapUiSmallMarginTop"
                />
                <Input
                    id="dIpZincType"
                    value="{regularize>/ZincType}"
                    width="100%"
                    showValueHelp="true"
                    liveChange=".onValueHelpLiveSearch"
                    valueHelpRequest="onValueHelpRequest"
                    placeholder="Enter incident type"
                />
                <TextArea
                    id="_IDGenText90"
                    rows="3"
                    enabled="false"
                    width="100%"
                    visible="{
                        path: 'regularize>/ZincTypeDesc',
                        formatter: '.formatVisibility'
                    }"
                    value="{regularize>/ZincTypeDesc}"
                />
                <VBox
                    id="_IDGenHBox5"
                    justifyContent="SpaceBetween"
                    alignItems="Center"
                >
                    <HBox
                        id="_IDGenHBox9"
                        alignItems="Start"
                        width="100%"
                    >
                        <Label
                            id="_IDGenLabel87"
                            text="First Incident Date"
                            class="sapUiSmallMarginEnd"
                        />
                        <Text
                            id="_IDGenText71"
                            text="{
                                    path: 'regularize>/ZfirstIncDate',
                                    type: 'sap.ui.model.type.Date',
                                    formatOptions: {
                                        pattern: 'dd-MM-yyyy'
                                    }
                            }"
                        />
                    </HBox>
                    <HBox
                        id="_IDGenHBox8"
                        alignContent="SpaceBetween"
                    >
                        <HBox
                            id="_IDGenHBox10"
                            alignItems="Center"
                        >
                            <Label
                                id="_IDGenLabel88"
                                text="System Repeat Count"
                                class="sapUiSmallMarginEnd"
                            />
                            <Input
                                id="_IDGenInput4"
                                editable="false"
                                value="{regularize>/Zrepeatcount}"
                            />
                        </HBox>
                        <HBox
                            id="_IDGenHBox11"
                            alignItems="Center"
                        >
                            <Label
                                id="_IDGenLabel104"
                                text="Repeat Count"
                                required="true"
                                class="sapUiSmallMarginEnd"
                            />
                            <Input
                                id="_IDGenInput5"
                                required="true"
                                value="{regularize>/Zsysrepeatcount}"
                                change=".onRepeatCountChange"
                            />
                        </HBox>
                    </HBox>
                </VBox>

                <Label
                    id="_IDGenLabel85"
                    text="Reason / Remarks"
                    class="sapUiSmallMarginTop"
                />
                <TextArea
                    id="dTaReason"
                    value="{regularize>/reason}"
                    width="100%"
                    rows="4"
                    placeholder="Enter reason or remarks"
                />
            </VBox>
        </content>

        <beginButton>
            <Button
                id="_IDGenButton16"
                text="Submit"
                type="Emphasized"
                press=".onSubmitTakeAction"
            />
        </beginButton>

        <endButton>
            <Button
                id="_IDGenButton17"
                text="Cancel"
                press=".onCloseTakeActionDialog"
            />
        </endButton>
    </Dialog>
</core:FragmentDefinition>
