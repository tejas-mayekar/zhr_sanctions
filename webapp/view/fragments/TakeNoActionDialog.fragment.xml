<core:FragmentDefinition
    xmlns:core="sap.ui.core"
    xmlns:f="sap.f"
    xmlns="sap.m"
>
    <Dialog
        id="TakeNoActionDialog"
        title="Take Action"
        type="Standard"
        class="sapUiResponsiveMargin"
        contentWidth="600px"
    >
        <content>
            <VBox
                id="_IDGenVBox6"
                class="sapUiMediumMargin"
            >
                <Label
                    id="_IDGenLabel86"
                    text="Reason / Remarks"
                    required="true"
                />
                <TextArea
                    id="dTaNaReason"
                    value="{regularize>/reason}"
                    width="100%"
                    rows="4"
                    placeholder="Enter reason or remarks"
                    required="true"
                />
            </VBox>
        </content>

        <beginButton>
            <Button
                id="_IDGenButton13"
                text="Submit"
                type="Emphasized"
                press=".onSubmitTakeNoAction"
            />
        </beginButton>

        <endButton>
            <Button
                id="_IDGenButton18"
                text="Cancel"
                press=".onCloseTakeNoActionDialog"
            />
        </endButton>
    </Dialog>
</core:FragmentDefinition>
