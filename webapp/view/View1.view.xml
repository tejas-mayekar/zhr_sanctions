<mvc:View
    controllerName="zhrsanctions.controller.View1"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.f"
    xmlns:layout="sap.ui.layout"
    xmlns:t="sap.ui.table"
    xmlns="sap.m"
>
    <f:DynamicPage
        id="dynamicPageId"
        headerExpanded="{/headerExpanded}"
        toggleHeaderOnTitleClick="{/titleClickable}"
        fitContent="true"
    >
        <!-- DynamicPage Title -->
        <f:title>
            <f:DynamicPageTitle>
                <f:heading>
                    <Title text="{i18n>title}" />
                </f:heading>
            </f:DynamicPageTitle>
        </f:title>

        <!-- DynamicPage Header -->

        <!-- DynamicPage Content -->
        <f:content>
            <t:Table
                id="sanctionsTable"
                selectionMode="None"
                enableSelectAll="false"
                rows="{path: '/HDR_STRSet'}"
                threshold="15"
                scrollThreshold="50"
                enableBusyIndicator="true"
                ariaLabelledBy="title"
                visibleRowCountMode="Auto"
                minAutoRowCount="5"
            >
                <!-- No Data placeholder with visible icon -->
                <t:noData>
                    <VBox
                        alignItems="Center"
                        justifyContent="Center"
                        height="100%"
                        width="100%"
                        class="sapUiMediumMargin"
                    >
                        <core:Icon
                            src="sap-icon://inbox"
                            size="3rem"
                            color="sapContent_NonInteractiveIconColor"
                            class="sapUiSmallMarginBottom"
                        />
                        <Text text="No data available" />
                    </VBox>
                </t:noData>

                <t:extension>
                    <OverflowToolbar style="Clear">
                        <Input showClearIcon="true" width="25rem" />
                        <ToolbarSpacer />
                        <Button
                            icon="sap-icon://refresh"
                            tooltip="Reinitialize Model"
                            press=".onModelRefresh"
                        />
                    </OverflowToolbar>
                </t:extension>

                <t:columns>
                    <t:Column
                        sortProperty="Name"
                        filterProperty="Name"
                        autoResizable="true"
                        width="11rem"
                    >
                        <Label text="{/#Product/Name/@sap:label}" />
                        <t:template>
                            <Text
                                text="{ZactionRefNo}"
                                wrapping="false"
                            />
                        </t:template>
                    </t:Column>
                </t:columns>

                <t:footer>
                    <OverflowToolbar>
                        <Label
                            visible="{= ${/itemCount} > 0 }"
                            text="Number of Violations: {/itemCount}"
                        />
                    </OverflowToolbar>
                </t:footer>
            </t:Table>
        </f:content>
    </f:DynamicPage>
</mvc:View>
