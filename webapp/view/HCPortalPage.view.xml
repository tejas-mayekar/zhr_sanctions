<mvc:View
    controllerName="zhrsanctions.controller.HCPortalPage"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.f"
    xmlns:t="sap.ui.table"
    xmlns="sap.m"
>
    <f:DynamicPage
        id="_IDGenDynamicPage"
        fitContent="true"
    >
        <f:title>
            <f:DynamicPageTitle id="_IDGenDynamicPageTitle1">
                <f:navigationActions>
                    <Button
                        id="backBtn"
                        icon="sap-icon://nav-back"
                        tooltip="Back to main page"
                        press=".onNavBack"
                    />
                </f:navigationActions>
                <f:heading>
                    <Title
                        id="_IDGenTitle1"
                        text="HC Portal"
                    />
                </f:heading>
            </f:DynamicPageTitle>
        </f:title>

        <f:content>
            <IconTabBar
                id="_IDGenIconTabBar"
                expanded="true"
                stretchContentHeight="true"
                class="sapUiResponsiveContentPadding"
                select=".onTabSelect"
            >
                <!-- ─── CURRENT TAB ─── -->
                <items>
                    <IconTabFilter
                        id="_IDGenIconTabFilter"
                        text="In Progress with HC"
                        icon="sap-icon://activity-items"
                        iconDensityAware="false"
                        design="Horizontal"
                        class="sapUiResponsiveContentPadding custom-tab-filter"
                        key="current"
                    >
                        <t:Table
                            id="HcTable"
                            selectionMode="None"
                            enableSelectAll="false"
                            rows="{path: '/ITM_STRSet'}"
                            threshold="15"
                            scrollThreshold="50"
                            enableBusyIndicator="true"
                            rowMode="Auto"
                        >
                            <t:noData>
                                <VBox
                                    id="_IDGenVBox4"
                                    alignItems="Center"
                                    justifyContent="Center"
                                    class="sapUiMediumMargin"
                                >
                                    <core:Icon
                                        id="_IDGenIcon4"
                                        src="sap-icon://inbox"
                                        size="3rem"
                                        color="sapContent_NonInteractiveIconColor"
                                        class="sapUiSmallMarginBottom"
                                    />
                                    <Text
                                        id="_IDGenText31"
                                        text="No data available"
                                    />
                                </VBox>
                            </t:noData>
                            <!-- Frozen "Actions" column — index 0, frozen on the LEFT -->
                            <t:columns>
                                <t:Column
                                    id="_IDGenColumn"
                                    width="8rem"
                                    hAlign="Center"
                                >
                                    <Label
                                        id="_IDGenLabel2"
                                        text="Actions"
                                    />
                                    <t:template>
                                        <Button
                                            id="_IDGenButton6"
                                            icon="sap-icon://detail-view"
                                            text="Details"
                                            type="Transparent"
                                            press=".onViewDetails"
                                        />
                                    </t:template>
                                </t:Column>
                            </t:columns>

                            <t:extension>
                                <OverflowToolbar
                                    id="_IDGenOverflowToolbar4"
                                    style="Standard"
                                >
                                    <HBox
                                        id="_IDGenHBox2"
                                        alignItems="Center"
                                        columnGap="0.5rem"
                                    >
                                        <core:Icon
                                            id="_IDGenIcon5"
                                            src="sap-icon://search"
                                        />
                                        <Input
                                            id="_IDGenInput"
                                            showClearIcon="true"
                                            width="25rem"
                                            placeholder="Search..."
                                            liveChange=".onSearchHistory"
                                        />
                                    </HBox>
                                    <ToolbarSpacer id="_IDGenToolbarSpacer2" />
                                    <Button
                                        id="_IDGenButton10"
                                        icon="sap-icon://refresh"
                                        tooltip="Refresh"
                                        press=".onRefreshHistory"
                                    />
                                    <Button
                                        id="_IDGenButtonExportHCData"
                                        icon="sap-icon://excel-attachment"
                                        tooltip="Export to Excel"
                                        press=".onExportHCData"
                                    />
                                </OverflowToolbar>
                            </t:extension>

                            <t:footer>
                                <OverflowToolbar id="_IDGenOverflowToolbar6">
                                    <Label
                                        id="_IDGenLabel34"
                                        visible="{= ${/historyCount} > 0 }"
                                        text="Number of Records: {/historyCount}"
                                    />
                                </OverflowToolbar>
                            </t:footer>
                        </t:Table>
                    </IconTabFilter>
                </items>
                <items>
                    <!-- ─── COMPLETED TAB ─── -->
                    <IconTabFilter
                        id="_IDGenIconTabFilterCompleted"
                        text="In Progress / Completed"
                        icon="sap-icon://complete"
                        iconDensityAware="false"
                        design="Horizontal"
                        class="sapUiResponsiveContentPadding custom-tab-filter"
                        key="completed"
                    >
                        <t:Table
                            id="HcCompletedTable"
                            selectionMode="None"
                            enableSelectAll="false"
                            rows="{path: '/ITM_COMPLETED_SET'}"
                            threshold="15"
                            scrollThreshold="50"
                            enableBusyIndicator="true"
                            rowMode="Auto"
                        >
                            <t:noData>
                                <VBox
                                    id="_IDGenVBox16"
                                    alignItems="Center"
                                    justifyContent="Center"
                                    class="sapUiMediumMargin"
                                >
                                    <core:Icon
                                        id="_IDGenIcon8"
                                        src="sap-icon://inbox"
                                        size="3rem"
                                        color="sapContent_NonInteractiveIconColor"
                                        class="sapUiSmallMarginBottom"
                                    />
                                    <Text
                                        id="_IDGenText92"
                                        text="No data available"
                                    />
                                </VBox>
                            </t:noData>

                            <t:columns>
                                <t:Column
                                    id="_IDGenColumnCompleted"
                                    width="8rem"
                                    hAlign="Center"
                                >
                                    <Label
                                        id="_IDGenLabel106"
                                        text="Actions"
                                    />
                                    <t:template>
                                        <Button
                                            id="_IDGenButton23"
                                            icon="sap-icon://detail-view"
                                            text="Details"
                                            type="Transparent"
                                            press=".onViewCompletedDetails"
                                        />
                                    </t:template>
                                </t:Column>
                            </t:columns>

                            <t:extension>
                                <OverflowToolbar
                                    id="_IDGenOverflowToolbar8"
                                    style="Standard"
                                >
                                    <HBox
                                        id="_IDGenHBox13"
                                        alignItems="Center"
                                        columnGap="0.5rem"
                                    >
                                        <core:Icon
                                            id="_IDGenIcon9"
                                            src="sap-icon://search"
                                        />
                                        <Input
                                            id="_IDGenInputCompleted"
                                            showClearIcon="true"
                                            width="25rem"
                                            placeholder="Search..."
                                            liveChange=".onSearchCompleted"
                                        />
                                    </HBox>
                                    <ToolbarSpacer id="_IDGenToolbarSpacer4" />
                                    <Button
                                        id="_IDGenButton24"
                                        icon="sap-icon://refresh"
                                        tooltip="Refresh"
                                        press=".onRefreshCompleted"
                                    />
                                    <Button
                                        id="_IDGenButtonExportCompleted"
                                        icon="sap-icon://excel-attachment"
                                        tooltip="Export to Excel"
                                        press=".onExportCompleted"
                                    />
                                </OverflowToolbar>
                            </t:extension>

                            <t:footer>
                                <OverflowToolbar id="_IDGenOverflowToolbar9">
                                    <Label
                                        id="_IDGenLabel107"
                                        visible="{= ${/completedCount} > 0 }"
                                        text="Number of Records: {/completedCount}"
                                    />
                                </OverflowToolbar>
                            </t:footer>
                        </t:Table>
                    </IconTabFilter>
                </items>
                <items>
                    <!-- ─── UNATTENDED TAB ─── -->
                    <IconTabFilter
                        id="_IDGenIconTabFilterNew"
                        text="Unattended"
                        icon="sap-icon://begin"
                        iconDensityAware="false"
                        design="Horizontal"
                        class="sapUiResponsiveContentPadding custom-tab-filter"
                        key="new"
                    >
                        <t:Table
                            id="HcNewTable"
                            selectionMode="None"
                            enableSelectAll="false"
                            rows="{path: '/ITM_NEW_SET'}"
                            threshold="15"
                            scrollThreshold="50"
                            enableBusyIndicator="true"
                            rowMode="Auto"
                        >
                            <t:noData>
                                <VBox
                                    id="_IDGenVBox15"
                                    alignItems="Center"
                                    justifyContent="Center"
                                    class="sapUiMediumMargin"
                                >
                                    <core:Icon
                                        id="_IDGenIcon6"
                                        src="sap-icon://inbox"
                                        size="3rem"
                                        color="sapContent_NonInteractiveIconColor"
                                        class="sapUiSmallMarginBottom"
                                    />
                                    <Text
                                        id="_IDGenText91"
                                        text="No data available"
                                    />
                                </VBox>
                            </t:noData>

                            <t:columns>
                                <t:Column
                                    id="_IDGenColumnNew"
                                    width="8rem"
                                    hAlign="Center"
                                >
                                    <Label
                                        id="_IDGenLabel64"
                                        text="Actions"
                                    />
                                    <t:template>
                                        <Button
                                            id="_IDGenButton21"
                                            icon="sap-icon://detail-view"
                                            text="Details"
                                            type="Transparent"
                                            press=".onViewNewDetails"
                                        />
                                    </t:template>
                                </t:Column>
                            </t:columns>

                            <t:extension>
                                <OverflowToolbar
                                    id="_IDGenOverflowToolbar10"
                                    style="Standard"
                                >
                                    <HBox
                                        id="_IDGenHBox12"
                                        alignItems="Center"
                                        columnGap="0.5rem"
                                    >
                                        <core:Icon
                                            id="_IDGenIcon7"
                                            src="sap-icon://search"
                                        />
                                        <Input
                                            id="_IDGenInputNew"
                                            showClearIcon="true"
                                            width="25rem"
                                            placeholder="Search..."
                                            liveChange=".onSearchNew"
                                        />
                                    </HBox>
                                    <ToolbarSpacer id="_IDGenToolbarSpacer5" />
                                    <Button
                                        id="_IDGenButton22"
                                        icon="sap-icon://refresh"
                                        tooltip="Refresh"
                                        press=".onRefreshNew"
                                    />
                                    <Button
                                        id="_IDGenButtonExportNew"
                                        icon="sap-icon://excel-attachment"
                                        tooltip="Export to Excel"
                                        press=".onExportNew"
                                    />
                                </OverflowToolbar>
                            </t:extension>

                            <t:footer>
                                <OverflowToolbar id="_IDGenOverflowToolbar7">
                                    <Label
                                        id="_IDGenLabel105"
                                        visible="{= ${/newCount} > 0 }"
                                        text="Number of Records: {/newCount}"
                                    />
                                </OverflowToolbar>
                            </t:footer>
                        </t:Table>
                    </IconTabFilter>
                </items>
                <items>
                 <IconTabFilter 
                        id="_IDGenIconTabFilter1"
                        text="Report"
                        icon="sap-icon://bullet-text"
                        iconDensityAware="false"
                        design="Horizontal"
                        class="sapUiResponsiveContentPadding custom-tab-filter"
                        key="new"
                    >
                    <t:Table
                            id="HcReportTable"
                            selectionMode="None"
                            enableSelectAll="false"
                            rows="{path: '/ITM_NEW_SET'}"
                            threshold="15"
                            scrollThreshold="50"
                            enableBusyIndicator="true"
                            rowMode="Auto"
                        >
                            <t:noData>
                                <VBox id="_IDGenVBox20"
                                    alignItems="Center"
                                    justifyContent="Center"
                                    class="sapUiMediumMargin"
                                >
                                    <core:Icon id="_IDGenIcon10"
                                        src="sap-icon://inbox"
                                        size="3rem"
                                        color="sapContent_NonInteractiveIconColor"
                                        class="sapUiSmallMarginBottom"
                                    />
                                    <Text id="_IDGenText124"
                                        text="No data available"
                                    />
                                </VBox>
                            </t:noData>

                            <t:columns>
                                <t:Column id="_IDGenColumn1"
                                    width="8rem"
                                    hAlign="Center"
                                >
                                    <Label id="_IDGenLabel140"
                                        text="Actions"
                                    />
                                    <t:template>
                                        <Button id="_IDGenButton30"
                                            icon="sap-icon://detail-view"
                                            text="Details"
                                            type="Transparent"
                                            press=".onViewNewDetails"
                                        />
                                    </t:template>
                                </t:Column>
                            </t:columns>

                            <t:extension>
                                <OverflowToolbar id="_IDGenOverflowToolbar12"
                                    style="Standard"
                                >
                                    <HBox id="_IDGenHBox18"
                                        alignItems="Center"
                                        columnGap="0.5rem"
                                    >
                                        <core:Icon id="_IDGenIcon11"
                                            src="sap-icon://search"
                                        />
                                        <Input id="_IDGenInput6"
                                            showClearIcon="true"
                                            width="25rem"
                                            placeholder="Search..."
                                            liveChange=".onSearchNew"
                                        />
                                    </HBox>
                                    <ToolbarSpacer id="_IDGenToolbarSpacer7" />
                                    <Button id="_IDGenButton31"
                                        icon="sap-icon://refresh"
                                        tooltip="Refresh"
                                        press=".onRefreshNew"
                                    />
                                    <Button id="_IDGenButton32"
                                        icon="sap-icon://excel-attachment"
                                        tooltip="Export to Excel"
                                        press=".onExportNew"
                                    />
                                </OverflowToolbar>
                            </t:extension>

                            <t:footer>
                                <OverflowToolbar id="_IDGenOverflowToolbar13" >
                                    <Label id="_IDGenLabel141"
                                        visible="{= ${/newCount} > 0 }"
                                        text="Number of Records: {/newCount}"
                                    />
                                </OverflowToolbar>
                            </t:footer>
                        </t:Table>
                    </IconTabFilter>
                </items>
            </IconTabBar>
        </f:content>
    </f:DynamicPage>
</mvc:View>
