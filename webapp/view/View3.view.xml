<mvc:View
    controllerName="zhrsanctions.controller.View3"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:f="sap.f"
    xmlns:core="sap.ui.core"
    xmlns:form="sap.ui.layout.form"
    xmlns="sap.m"
>
    <f:DynamicPage
        id="CreatePage"
        fitContent="true"
    >
        <!-- ─── Header ─── -->
        <f:title>
            <f:DynamicPageTitle id="_IDGenDynamicPageTitle2">
                <f:navigationActions>
                    <Button
                        id="createbtnBack"
                        icon="sap-icon://nav-back"
                        tooltip="Back to list"
                        press=".onNavBack"
                    />
                </f:navigationActions>
                <f:heading>
                    <Title id="createPageTitle" text="Create Violation" />
                </f:heading>
            </f:DynamicPageTitle>
        </f:title>

        <!-- ─── Content ─── -->
        <f:content>
            <VBox id="_IDGenVBox"
                class="sapUiMediumMargin"
            >
                <!-- ── Section 1: Employee Details ── -->
                <Panel id="_IDGenPanel"
                    headerText="File New Violation"
                    class="sapUiSmallMarginBottom"
                >
             
                        <HBox id="_IDGenHBox2" width="32rem" justifyContent="SpaceBetween" alignItems="Center">
     <Label id="_IDGenLabel2" text="Employee ID : " />
     <Input id="_IDGenInput" type="Text" width="30rem" />
                        </HBox>
               
                </Panel>
                </VBox>
        </f:content>
    </f:DynamicPage>
</mvc:View>